# ============================================================
# Variables d'environnement Mailys Solutions
# Copier vers .env.local (dev) et dans Vercel → Settings →
# Environment Variables (production).
# Sans ces variables, le site fonctionne avec le contenu de
# secours intégré ; l'admin et le formulaire sont désactivés.
# ============================================================

# --- Supabase (Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- SMTP notifications contact (optionnel, ex: OVH/Ionos) ---
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
CONTACT_NOTIFY_TO=contact@mailys-solutions.fr

# --- BugTrack (signalement de bugs, espace admin) ---
# site_key reste serveur uniquement (jamais NEXT_PUBLIC) : la
# route /api/bugtrack le relaie, il ne transite jamais au navigateur.
BUGTRACK_SITE_KEY=
BUGTRACK_API_URL=https://bugtrack.com/api/tickets/create

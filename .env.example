# ============================================================
# Variables d'environnement Mailys Solutions
# Copier vers .env.local (dev) et dans Vercel → Settings →
# Environment Variables (production).
# Sans ces variables, le site fonctionne avec le contenu de
# secours intégré ; l'admin et le formulaire sont désactivés.
# ============================================================

# --- Supabase (Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- SMTP notifications contact (optionnel, ex: OVH/Ionos) ---
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
CONTACT_NOTIFY_TO=contact@mailys-solutions.fr

# --- BugTrack (signalement de bugs, espace admin) ---
# Clé générée sur bugtrack.ohiho.fr/admin/sites.
# JAMAIS de préfixe NEXT_PUBLIC_ : la clé doit rester côté serveur,
# sinon n'importe qui pourrait créer des tickets au nom du site.
BUGTRACK_API_URL=https://bugtrack.ohiho.fr
BUGTRACK_SITE_KEY=

# Cle de service Supabase — gestion des acces clients (JAMAIS NEXT_PUBLIC)
# Supabase -> Settings -> API -> service_role
SUPABASE_SERVICE_ROLE_KEY=
